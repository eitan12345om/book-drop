{
  "name": "book-drop",
  "version": "1.0.0",
  "description": "Send ebooks to Kobo/Kindle ereaders easily",
  "homepage": "https://bookdrop.cc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eitan12345om/book-drop.git"
  },
  "bugs": {
    "url": "https://github.com/eitan12345om/book-drop/issues"
  },
  "keywords": [
    "ebook",
    "kobo",
    "kindle",
    "ereader",
    "tolino",
    "transfer",
    "epub",
    "mobi",
    "pdf"
  ],
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node --env-file=.env dist/server.js",
    "dev": "concurrently \"sass --watch client/scss/base.scss:client/public/base.css client/scss/upload.scss:client/public/upload.css client/scss/download.scss:client/public/download.css\" \"tsx watch --env-file=.env src/server.ts\"",
    "build:css": "sass client/scss/base.scss:client/public/base.css client/scss/upload.scss:client/public/upload.css client/scss/download.scss:client/public/download.css --style=compressed --no-source-map",
    "build": "pnpm build:css && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "lint:fix": "oxlint --fix src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test 'tests/*.test.ts'",
    "test:watch": "node --import tsx --test --watch 'tests/*.test.ts'",
    "coverage": "c8 --reporter=text --reporter=html node --import tsx --test 'tests/*.test.ts'",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{html,css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "contributors": [
    {
      "name": "djazz",
      "url": "https://github.com/daniel-j"
    },
    {
      "name": "eitan12345om",
      "url": "https://github.com/eitan12345om"
    }
  ],
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "file-type": "^21.3.3",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "sanitize-filename": "^1.6.4",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
